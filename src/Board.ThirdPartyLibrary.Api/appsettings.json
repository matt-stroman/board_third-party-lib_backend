{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Authentication": {
    "Keycloak": {
      "BaseUrl": "https://localhost:8443",
      "Realm": "board-third-party-library",
      "ClientId": "board-third-party-library-backend",
      "ClientSecret": "board-third-party-library-backend-secret",
      "PublicBackendBaseUrl": "https://localhost:7085",
      "RequireHttpsMetadata": true,
