      "ExternalIdentityProviders": []
    }
  },
  "ConnectionStrings": {
    "BoardLibrary": ""
  },
  "TitleMediaStorage": {
    "RootPath": "artifacts/title-media"
  },
  "AllowedHosts": "*"
}
