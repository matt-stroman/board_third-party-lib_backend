{
  "realm": "board-enthusiasts",
  "enabled": true,
  "displayName": "Board Enthusiasts",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "editUsernameAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "verifyEmail": true,
  "rememberMe": true,
  "smtpServer": {
    "from": "no-reply@boardtpl.local",
    "fromDisplayName": "Board Enthusiasts",
    "host": "mailpit",
    "port": "1025",
    "auth": "false",
    "starttls": "true",
    "ssl": "false"
  },
  "roles": {
    "realm": [
      {
        "name": "player",
        "description": "Player role for Board Enthusiasts users."
      },
      {
        "name": "developer",
        "description": "Developer role for Board Enthusiasts users."
      },
      {
        "name": "admin",
        "description": "Administrator role for Board Enthusiasts users."
      },
      {
        "name": "moderator",
        "description": "Moderator role for Board Enthusiasts users."
      },
      {
        "name": "default-roles-board-enthusiasts",
        "description": "${role_default-roles}",
        "composite": true,
        "composites": {
          "realm": [
            "offline_access",
            "player"
          ],
          "client": {
            "account": [
              "manage-account",
              "view-profile"
            ]
          }
        }
      }
    ]
  },
  "defaultRole": {
    "name": "default-roles-board-enthusiasts",
    "description": "${role_default-roles}",
    "composite": true
  },
  "clients": [
    {
      "clientId": "board-enthusiasts-backend",
      "name": "Board Enthusiasts Backend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "secret": "board-enthusiasts-backend-secret",
      "redirectUris": [
        "https://localhost:7085/identity/auth/callback"
      ],
      "webOrigins": [
        "https://localhost:7085"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "https://localhost:7085/*"
      }
    },
    {
      "clientId": "board-enthusiasts-web",
      "name": "Board Enthusiasts Web UI",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "board-enthusiasts-web-secret",
      "redirectUris": [
        "https://localhost:7277/signin-oidc"
      ],
      "webOrigins": [
        "https://localhost:7277"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "https://localhost:7277/signout-callback-oidc"
      }
    }
  ],
  "users": [
    {
      "username": "local-admin",
      "enabled": true,
      "email": "admin@boardtpl.local",
      "emailVerified": true,
      "firstName": "Local",
      "lastName": "Admin",
      "realmRoles": [
        "player",
        "developer",
        "admin"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "ChangeMe!123",
          "temporary": false
        }
      ]
    },
    {
      "username": "service-account-board-enthusiasts-backend",
      "enabled": true,
      "serviceAccountClientId": "board-enthusiasts-backend",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users",
          "view-realm"
        ]
      }
    }
  ]
}
